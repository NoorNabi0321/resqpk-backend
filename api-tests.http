### ResQPK API tests (VS Code REST Client / reference for Postman)
### Replace TOKEN_HERE values with tokens returned by the login/register responses.

@baseUrl = http://localhost:3000

### Health Check
GET {{baseUrl}}/health

### Register Patient
POST {{baseUrl}}/api/auth/patient/register
Content-Type: application/json

{
  "full_name": "Ahmed Khan",
  "phone": "03001234567",
  "password": "Test1234!"
}

### Login Patient
POST {{baseUrl}}/api/auth/patient/login
Content-Type: application/json

{
  "phone": "03001234567",
  "password": "Test1234!"
}

### Register Driver
POST {{baseUrl}}/api/auth/driver/register
Content-Type: application/json

{
  "full_name": "Usman Ali",
  "phone": "03009876543",
  "password": "Driver1234!",
  "vehicle_number": "SBC-123",
  "license_number": "HYD-DL-2024-001",
  "organization": "Private"
}

### Login Driver
POST {{baseUrl}}/api/auth/driver/login
Content-Type: application/json

{
  "phone": "03009876543",
  "password": "Driver1234!"
}

### Hospital Admin Login (created in Part C)
POST {{baseUrl}}/api/auth/hospital/login
Content-Type: application/json

{
  "email": "admin@civilhospital.resqpk.app",
  "password": "HospAdmin2024!"
}

### Get My Profile (replace TOKEN with token from a login response)
GET {{baseUrl}}/api/auth/me
Authorization: Bearer TOKEN_HERE

### Update Medical Profile (patient token required)
PUT {{baseUrl}}/api/auth/medical-profile
Authorization: Bearer TOKEN_HERE
Content-Type: application/json

{
  "blood_group": "O+",
  "chronic_conditions": ["Diabetes"],
  "allergies": ["Penicillin"],
  "emergency_contact_name": "Fatima Khan",
  "emergency_contact_phone": "03331234567",
  "emergency_contact_relation": "Wife"
}

### Refresh Token
POST {{baseUrl}}/api/auth/refresh
Authorization: Bearer TOKEN_HERE

### Protected route without token (should return 401)
GET {{baseUrl}}/api/auth/me

### Wrong role: medical-profile with a driver token (should return 403)
PUT {{baseUrl}}/api/auth/medical-profile
Authorization: Bearer DRIVER_TOKEN_HERE
Content-Type: application/json

{ "blood_group": "A+" }

###############################################################################
# MODULE 4 — SOS + Dispatch
###############################################################################

### Trigger SOS (patient token) — returns fast, dispatch runs in background
POST {{baseUrl}}/api/sos/trigger
Authorization: Bearer PATIENT_TOKEN_HERE
Content-Type: application/json

{
  "lat": 25.3792,
  "lng": 68.3683,
  "accuracy": 15,
  "triggerMethod": "app_sos"
}

### Driver respond - Accept (driver token, use caseId from SOS response)
POST {{baseUrl}}/api/cases/respond
Authorization: Bearer DRIVER_TOKEN_HERE
Content-Type: application/json

{
  "caseId": "CASE_ID_HERE",
  "response": "accepted"
}

### Get case details (patient or assigned driver token)
GET {{baseUrl}}/api/cases/CASE_ID_HERE
Authorization: Bearer PATIENT_TOKEN_HERE

### Update status - Driver arrived at patient
PUT {{baseUrl}}/api/cases/status
Authorization: Bearer DRIVER_TOKEN_HERE
Content-Type: application/json

{ "caseId": "CASE_ID_HERE", "status": "arrived" }

### Update status - En route to hospital
PUT {{baseUrl}}/api/cases/status
Authorization: Bearer DRIVER_TOKEN_HERE
Content-Type: application/json

{ "caseId": "CASE_ID_HERE", "status": "en_route" }

### Update status - Completed (driver freed)
PUT {{baseUrl}}/api/cases/status
Authorization: Bearer DRIVER_TOKEN_HERE
Content-Type: application/json

{ "caseId": "CASE_ID_HERE", "status": "completed" }

### Family tracking (public — no auth)
GET {{baseUrl}}/api/cases/track/SHARE_TOKEN_HERE

### Cancel SOS (patient token)
POST {{baseUrl}}/api/sos/cancel
Authorization: Bearer PATIENT_TOKEN_HERE
Content-Type: application/json

{ "caseId": "CASE_ID_HERE", "reason": "false_alarm" }

### Missed-call webhook (simulating the Android gateway — public)
POST {{baseUrl}}/api/sos/missed-call-webhook
Content-Type: application/json

{
  "callerPhone": "03781980656",
  "gatewaySecret": "your-secret-from-env"
}

###############################################
# Module 6 — AI Report Generator
###############################################

### Generate AI Report (text only — easiest to test)
POST http://localhost:3000/api/ai/report
Authorization: Bearer PATIENT_TOKEN
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="case_id"

CASE_ID_HERE
--boundary
Content-Disposition: form-data; name="text"

Patient is a 50 year old male with severe chest pain and difficulty breathing. He is diabetic and takes insulin. No known drug allergies.
--boundary
Content-Disposition: form-data; name="language"

en
--boundary--

### Get Report
GET http://localhost:3000/api/ai/report/CASE_ID_HERE
Authorization: Bearer PATIENT_TOKEN

###############################################
# Module 7 — Offline SOS (SMS gateway)
# Secret must match SMS_GATEWAY_SECRET in .env
###############################################

### SMS webhook — wrong secret (200, reason unauthorized)
POST http://localhost:3000/api/sos/sms-webhook
Content-Type: application/json

{
  "callerPhone": "03001234567",
  "messageBody": "SOS",
  "gatewaySecret": "wrong-secret"
}

### SMS webhook — not a trigger keyword (200, reason not_a_trigger)
POST http://localhost:3000/api/sos/sms-webhook
Content-Type: application/json

{
  "callerPhone": "03001234567",
  "messageBody": "hello how are you",
  "gatewaySecret": "resqpk-gateway-secret-2026-hyderabad"
}

### SMS webhook — unregistered number (200, reason not_registered)
POST http://localhost:3000/api/sos/sms-webhook
Content-Type: application/json

{
  "callerPhone": "03009999999",
  "messageBody": "SOS",
  "gatewaySecret": "resqpk-gateway-secret-2026-hyderabad"
}

### SMS webhook — valid SOS (registered patient WITH last_known_location)
POST http://localhost:3000/api/sos/sms-webhook
Content-Type: application/json

{
  "callerPhone": "03781980656",
  "messageBody": "SOS chest pain",
  "gatewaySecret": "resqpk-gateway-secret-2026-hyderabad"
}

### Update last-known location (patient token)
PUT http://localhost:3000/api/auth/location
Authorization: Bearer PATIENT_TOKEN
Content-Type: application/json

{
  "lat": 25.3792,
  "lng": 68.3683,
  "accuracy": 12.5
}

###############################################
# Module 8 — First Aid Library
###############################################

### Get all first aid guides (public)
GET http://localhost:3000/api/first-aid

### Get Urdu guides
GET http://localhost:3000/api/first-aid?lang=ur

### Get featured guides only
GET http://localhost:3000/api/first-aid?featured=true

### Get single guide by slug
GET http://localhost:3000/api/first-aid/cpr-guide

### Send weekly notification (dev: no auth; prod: super_admin)
POST http://localhost:3000/api/first-aid/send-weekly-notification

### Register / refresh FCM token (Module 8 B2)
PUT http://localhost:3000/api/auth/fcm-token
Authorization: Bearer PATIENT_TOKEN
Content-Type: application/json

{
  "fcmToken": "fcm-token-from-firebase-here"
}
