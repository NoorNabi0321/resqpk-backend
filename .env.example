NODE_ENV=development
PORT=3000

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT
JWT_SECRET=your-very-long-random-jwt-secret-minimum-64-characters
JWT_EXPIRES_IN=7d

# OpenRouteService (maps routing + ETA + geocoding)
ORS_API_KEY=your-openrouteservice-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Firebase Admin (FCM push notifications) — optional; sockets work without it
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# App
FRONTEND_URL=http://localhost:5173
# Production backend URL (Render): https://resqpk-backend.onrender.com
MISSED_CALL_GATEWAY_URL=http://your-android-gateway-url
MISSED_CALL_GATEWAY_SECRET=your-secret-key-for-android-gateway
